# =============================================================================
# .gitignore — 2D N-Body Gravitational Simulator
# Laboratorio 1: Programación paralela con OpenMP
# Universidad de Santiago de Chile
# =============================================================================

# -----------------------------------------------------------------------------
# Compiled binaries
# -----------------------------------------------------------------------------
nbody_2d/nbody_2d
nbody_2d/run_tests

# -----------------------------------------------------------------------------
# Object files
# -----------------------------------------------------------------------------
nbody_2d/*.o
nbody_2d/tests/*.o

# -----------------------------------------------------------------------------
# Generated simulation output
# -----------------------------------------------------------------------------
nbody_2d/*.dat
nbody_2d/*.png
nbody_2d/*.csv

# -----------------------------------------------------------------------------
# Orphan / stray files from project scaffolding
# -----------------------------------------------------------------------------
nbody_2d/make

# -----------------------------------------------------------------------------
# macOS system files
# -----------------------------------------------------------------------------
.DS_Store
**/.DS_Store
.__*

# -----------------------------------------------------------------------------
# Editor / IDE directories
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Valgrind / profiling output
# -----------------------------------------------------------------------------
callgrind.out.*
massif.out.*
gmon.out

# -----------------------------------------------------------------------------
# Python cache (used by Matplotlib plotting scripts)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# -----------------------------------------------------------------------------
# Docker build cache (not committed)
# -----------------------------------------------------------------------------
.dockerignore
